<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/camera_close"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:src="@drawable/camera_icon_close"
        />

    <ImageView
        android:id="@+id/camera_flash"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:padding="10dp"
        android:src="@drawable/camera_icon_flash_forbidden"
        />

    <RelativeLayout
        android:id="@+id/camera_bottom_layout"
        android:layout_alignParentBottom="true"
        android:layout_width="match_parent"
        android:layout_height="152dp">

        <com.martin.cmpt.camera.widget.AutoCenterHorizontalScrollView
            android:id="@+id/camera_mode_select"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            />
        <ImageView
            android:id="@+id/camera_takephoto"
            android:layout_marginTop="50dp"
            android:layout_centerHorizontal="true"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/camera_take_photo_btn"/>

        <ImageView
            android:id="@+id/camera_next"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="58dp"
            android:background="@drawable/camera_icon_mark_next"
            android:visibility="gone"/>

        <ImageView
            android:id="@+id/camera_right"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toRightOf="@+id/camera_takephoto"
            android:layout_marginLeft="46dp"
            android:padding="10dp"
            android:layout_marginTop="60dp"
            android:src="@drawable/camera_icon_switch_camera"/>

        <ImageView
            android:id="@+id/camera_left"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="46dp"
            android:layout_marginTop="60dp"
            android:layout_toLeftOf="@+id/camera_takephoto"
            android:padding="10dp"
            android:src="@drawable/camera_icon_back_to_preview" />
    </RelativeLayout>

    <FrameLayout
        android:id="@+id/camera_preview"
        android:layout_below="@+id/camera_close"
        android:layout_above="@+id/camera_bottom_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <ImageView
        android:id="@+id/camera_photo"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/camera_close"
        android:layout_above="@+id/camera_bottom_layout"
        android:visibility="gone"/>

    <me.pqpo.smartcropperlib.view.CropImageView
        android:id="@+id/crop_imageview"
        android:layout_below="@+id/camera_close"
        android:layout_above="@+id/camera_bottom_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        app:civShowGuideLine="false"
        app:civShowEdgeMidPoint="true"
        app:civLineColor="@color/colorPrimary"
        app:civMagnifierCrossColor="@color/colorPrimaryDark"
        android:visibility="gone"/>
</RelativeLayout>